# Telegram Bot Token（用于转发消息）
TELEGRAM_BOT_TOKEN=

# Telegram MTProto 客户端配置（用于监听频道）
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# 定时拉取间隔（毫秒，默认 5000 即 5 秒）
FETCH_INTERVAL_MS=5000

# 启动时是否补拉离线消息：true=按 .state 游标补拉；false=游标对齐到最新、不处理停机积压
FETCH_ON_START=true

# DeepSeek API 配置（pipeline 中使用 translate 处理器时生效）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
